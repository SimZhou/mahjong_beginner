{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"index.html","title":"\u9ebb\u5c06\u5165\u95e8\u6559\u7a0b","text":"<p>\u8fd9\u662f\u4e00\u6761\u4ece\u96f6\u91cd\u5efa\u7684\u4e2d\u6587\u9ebb\u5c06\u6559\u7a0b\u7ad9\u70b9\u3002</p> <p>\u5f53\u524d\u7248\u672c\u7684\u76ee\u6807\u5f88\u660e\u786e\uff1a</p> <ol> <li>\u4ee5 <code>beginners.biz</code> \u539f\u59cb\u65e5\u6587\u9875\u9762\u4e3a\u552f\u4e00\u5185\u5bb9\u6765\u6e90</li> <li>\u6240\u6709\u9875\u9762\u91cd\u65b0\u7ffb\u8bd1\uff0c\u4e0d\u6cbf\u7528\u65e7\u7ad9\u673a\u7ffb\u6b8b\u7559</li> <li>\u6b63\u6587\u793a\u610f\u56fe\u5b8c\u6574\u4fdd\u7559</li> <li>\u9875\u9762\u7ed3\u6784\u6309\u4e2d\u6587\u9605\u8bfb\u4e60\u60ef\u91cd\u65b0\u6574\u7406</li> </ol>"},{"location":"index.html#_2","title":"\u5f53\u524d\u8fdb\u5ea6","text":"<p>\u7b2c\u4e00\u6279\u5df2\u7ecf\u91cd\u65b0\u843d\u5730\u7684\u5185\u5bb9\uff1a</p> <ol> <li>\u9ebb\u5c06\u57fa\u7840\u680f\u76ee\u5bfc\u8bfb</li> <li>\u9ebb\u5c06\u662f\u4ec0\u4e48</li> <li>\u9ebb\u5c06\u4e0e\u6982\u7387</li> </ol> <p>\u540e\u7eed\u9875\u9762\u4f1a\u6309\u680f\u76ee\u9010\u6b65\u8865\u9f50\u3002</p> <p>\u539f\u59cb\u65e5\u6587\u9875\uff1ahttp://beginners.biz/</p>"},{"location":"kihon/index.html","title":"\u9ebb\u5c06\u57fa\u7840","text":"<p>\u8fd9\u4e00\u680f\u5904\u7406\u7684\u662f\u6574\u5957\u6559\u7a0b\u91cc\u6700\u5e95\u5c42\u7684\u90e8\u5206\uff1a\u5148\u628a\u9ebb\u5c06\u8fd9\u95e8\u6e38\u620f\u5728\u7ed3\u6784\u4e0a\u770b\u6e05\u695a\uff0c\u518d\u53bb\u8c08\u724c\u7406\u3001\u624b\u5f79\u3001\u9632\u5b88\u548c\u5c40\u51b5\u3002</p> <p>\u5982\u679c\u57fa\u7840\u6982\u5ff5\u4e0d\u7a33\uff0c\u540e\u9762\u5f88\u591a\u201c\u4e3a\u4ec0\u4e48\u8fd9\u4e48\u6253\u201d\u90fd\u4f1a\u53d8\u6210\u6b7b\u8bb0\u786c\u80cc\u3002\u53cd\u8fc7\u6765\uff0c\u53ea\u8981\u628a\u8fd9\u91cc\u7684\u6846\u67b6\u5403\u900f\uff0c\u540e\u9762\u7684\u7ae0\u8282\u4f1a\u987a\u5f88\u591a\u3002</p>"},{"location":"kihon/index.html#_2","title":"\u672c\u680f\u5185\u5bb9","text":"<ol> <li> <p>\u9ebb\u5c06\u662f\u4ec0\u4e48 : \u5148\u8bf4\u660e\u9ebb\u5c06\u5230\u5e95\u662f\u4e00\u79cd\u600e\u6837\u7684\u6e38\u620f\uff0c\u4e3a\u4ec0\u4e48\u5b83\u65e2\u53d7\u8fd0\u6c14\u652f\u914d\uff0c\u53c8\u4f9d\u7136\u80fd\u62c9\u5f00\u6c34\u5e73\u5dee\u8ddd\u3002</p> </li> <li> <p>\u9ebb\u5c06\u4e0e\u6982\u7387 : \u8bb2\u6e05\u695a\u201c\u724c\u6548\u7387\u201d\u548c\u201c\u6982\u7387\u5224\u65ad\u201d\u4e3a\u4ec0\u4e48\u662f\u505a\u724c\u7684\u6838\u5fc3\uff0c\u800c\u4e0d\u662f\u5148\u8ff7\u4e0a\u67d0\u4e2a\u6f02\u4eae\u5f79\u79cd\u3002</p> </li> </ol> <p>\u540e\u7eed\u4f1a\u7ee7\u7eed\u8865\u5165\uff1a</p> <ol> <li>\u542c\u724c\u4e0e\u5411\u542c</li> <li>\u9762\u5b50\u4e0e\u642d\u5b50</li> <li>\u6570\u724c\u4e0e\u5b57\u724c</li> <li>\u5bf9\u5b50</li> <li>\u57fa\u672c\u5f62\u4e0e\u590d\u5408\u5f62</li> <li>\u9ebb\u5c06\u7684\u542c\u724c</li> </ol> <p>\u539f\u59cb\u65e5\u6587\u9875\uff1ahttp://beginners.biz/kihon/</p>"},{"location":"kihon/kihon01.html","title":"\u9ebb\u5c06\u662f\u4ec0\u4e48","text":"<p>\u8fd9\u5957\u6559\u7a0b\u4f1a\u4ee5\u201c\u724c\u7406\u201d\u548c\u201c\u5b9e\u6218\u5224\u65ad\u201d\u4e3a\u4e3b\u8f74\uff0c\u7cfb\u7edf\u8bb2\u6e05\u695a\u9ebb\u5c06\u91cc\u90a3\u4e9b\u771f\u6b63\u5f71\u54cd\u6210\u7ee9\u7684\u4e1c\u897f\u3002</p> <p>\u6211\u4f1a\u9ed8\u8ba4\u8bfb\u8005\u5df2\u7ecf\u77e5\u9053\u9ebb\u5c06\u89c4\u5219\u548c\u5e38\u89c1\u672f\u8bed\u3002\u5982\u679c\u8fd8\u4e0d\u719f\uff0c\u6700\u597d\u5148\u8865\u57fa\u7840\u89c4\u5219\uff0c\u518d\u56de\u6765\u770b\u8fd9\u4e00\u5957\u5185\u5bb9\u3002</p>"},{"location":"kihon/kihon01.html#_2","title":"\u9ebb\u5c06\u4e0e\u8fd0\u6c14","text":"<p>\u201c\u9ebb\u5c06\u91cc\u5230\u5e95\u6709\u6ca1\u6709\u8fd0\u6c14\u3001\u624b\u6c14\u3001\u6c14\u6d41\uff1f\u201d</p> <p>\u8fd9\u662f\u8ba8\u8bba\u5f88\u591a\u5e74\u7684\u8001\u95ee\u9898\u3002\u5148\u628a\u7ed3\u8bba\u8bf4\u6e05\u695a\uff1a</p> <ol> <li>\u9ebb\u5c06\u5f53\u7136\u975e\u5e38\u5403\u8fd0\u6c14</li> <li>\u4f46\u201c\u624b\u6c14\u201d\u5e76\u4e0d\u662f\u4e00\u4e2a\u53ef\u4ee5\u62ff\u6765\u6307\u5bfc\u6253\u6cd5\u7684\u53ef\u9760\u7406\u8bba</li> </ol> <p>\u4ece\u957f\u671f\u770b\uff0c\u6c34\u5e73\u9ad8\u4f4e\u6700\u7ec8\u8fd8\u662f\u4f1a\u4f53\u73b0\u5728\u6210\u7ee9\u4e0a\u3002\u4f46\u73b0\u5b9e\u91cc\uff0c\u4e00\u4e2a\u4eba\u4e0d\u53ef\u80fd\u8fde\u7eed\u6253\u4e0a\u5343\u4e2a\u534a\u5e84\uff0c\u628a\u77ed\u671f\u6ce2\u52a8\u5b8c\u5168\u62b9\u5e73\u3002\u591a\u6570\u65f6\u5019\uff0c\u4f60\u611f\u53d7\u5230\u7684\u80dc\u8d1f\uff0c\u5f88\u5927\u7a0b\u5ea6\u4e0a\u5c31\u662f\u5f53\u5929\u724c\u8fd0\u7684\u7ed3\u679c\u3002</p> <p>\u4e00\u665a\u6253\u4e24\u4e09\u4e2a\u534a\u5e84\uff0c\u6216\u8005\u4e00\u573a\u724c\u5c40\u91cc\u8fde\u7eed\u51e0\u624b\u6478\u5f97\u5f88\u597d\u3001\u8fde\u7eed\u51e0\u624b\u4ec0\u4e48\u90fd\u505a\u4e0d\u4e86\uff0c\u8fd9\u90fd\u5f88\u6b63\u5e38\u3002\u95ee\u9898\u5728\u4e8e\uff1a</p> <p>\u8fd9\u79cd\u6ce2\u52a8\u5b58\u5728\uff0c\u4e0d\u4ee3\u8868\u4f60\u80fd\u9760\u201c\u987a\u52bf\u201d\u201c\u501f\u6d41\u201d\u4e4b\u7c7b\u7684\u8bf4\u6cd5\u628a\u5b83\u5229\u7528\u8d77\u6765\u3002</p> <p>\u6bd4\u5982\u4e0b\u9762\u8fd9\u79cd\u5c40\u9762\uff1a</p> <p></p> <p>\u5982\u679c\u53ea\u662f\u56e0\u4e3a\u201c\u6211\u4eca\u5929\u72b6\u6001\u5f88\u597d\u201d\u201c\u8fd9\u628a\u611f\u89c9\u6c14\u5728\u6211\u8fd9\u8fb9\u201d\uff0c\u5c31\u53bb\u786c\u9876\u5371\u9669\u724c\uff0c\u90a3\u672c\u8d28\u4e0a\u4e0d\u662f\u8bfb\u61c2\u4e86\u8fd0\u52bf\uff0c\u53ea\u662f\u7ed9\u81ea\u5df1\u627e\u4e86\u4e00\u4e2a\u51b2\u52a8\u8fdb\u653b\u7684\u7406\u7531\u3002</p> <p>\u5728\u8fd9\u79cd\u70b9\u68d2\u72b6\u51b5\u4e0b\uff0c\u5408\u7406\u9009\u62e9\u901a\u5e38\u4e0d\u662f\u901e\u5f3a\uff0c\u800c\u662f\u8001\u8001\u5b9e\u5b9e\u9000\u5b88\u3002\u50cf\u628a\u53d1\u7684\u6697\u523b\u62c6\u51fa\u6765\u5f53\u5b89\u5168\u724c\uff0c\u8fd9\u79cd\u5904\u7406\u624d\u7b26\u5408\u724c\u5c40\u5229\u76ca\u3002</p> <p>\u6240\u4ee5\u8fd9\u91cc\u6700\u91cd\u8981\u7684\u4e00\u70b9\u662f\uff1a</p> <p>\u4e0d\u8981\u7528\u201c\u624b\u6c14\u201d\u201c\u6c14\u6d41\u201d\u7ed9\u4e0d\u5408\u7406\u7684\u6253\u724c\u627e\u501f\u53e3\u3002</p> <p>\u9ebb\u5c06\u5f53\u7136\u6709\u8fd0\u6c14\uff0c\u800c\u4e14\u8fd0\u6c14\u7ecf\u5e38\u51b3\u5b9a\u77ed\u671f\u7ed3\u679c\uff1b\u4f46\u5b83\u5e76\u4e0d\u4f1a\u7a33\u5b9a\u5730\u7ed9\u4f60\u63d0\u793a\u201c\u73b0\u5728\u8be5\u62fc\u201d\u8fd8\u662f\u201c\u73b0\u5728\u8be5\u64a4\u201d\u3002</p>"},{"location":"kihon/kihon01.html#_3","title":"\u9ebb\u5c06\u7684\u76ee\u7684","text":"<p>\u6765\u5b66\u9ebb\u5c06\u7684\u4eba\uff0c\u901a\u5e38\u90fd\u4f1a\u6709\u67d0\u79cd\u201c\u60f3\u53d8\u5f3a\u201d\u7684\u76ee\u6807\u3002\u6bd4\u5982\uff1a</p> <ol> <li>\u63d0\u9ad8\u5b9e\u6218\u6536\u652f</li> <li>\u63d0\u9ad8\u7ebf\u4e0a\u5e73\u53f0\u8bc4\u5206</li> <li>\u51b2\u66f4\u9ad8\u7684\u6bb5\u4f4d\u3001\u79f0\u53f7\u6216\u6392\u540d</li> </ol> <p>\u4f46\u8fd9\u5e76\u4e0d\u610f\u5473\u7740\u6240\u6709\u4eba\u6253\u9ebb\u5c06\u65f6\u7684\u4ef7\u503c\u53d6\u5411\u90fd\u5b8c\u5168\u4e00\u6837\u3002</p> <p>\u6709\u4eba\u6700\u5728\u610f\u957f\u671f\u6210\u7ee9\uff0c\u6709\u4eba\u5f88\u770b\u91cd\u201c\u80fd\u4e0d\u80fd\u62ff\u7b2c\u4e00\u201d\uff0c\u4e5f\u6709\u4eba\u5c31\u662f\u559c\u6b22\u505a\u5927\u724c\u3001\u505a\u5f79\u6ee1\u3002\u5c31\u7b97\u4ece\u6548\u7387\u89d2\u5ea6\u770b\u4e0d\u662f\u6700\u4f18\uff0c\u53ea\u8981\u662f\u89c4\u5219\u5141\u8bb8\u8303\u56f4\u5185\u7684\u4e2a\u4eba\u9009\u62e9\uff0c\u672c\u6765\u5c31\u6ca1\u6709\u5fc5\u8981\u62ff\u81ea\u5df1\u7684\u4ef7\u503c\u89c2\u53bb\u538b\u522b\u4eba\u3002</p> <p>\u4f8b\u5982\u4e0b\u9762\u8fd9\u79cd\u724c\uff1a</p> <p>\u4f8b\uff1a \u81ea\u6478 \u78b0</p> <p>\u4ece\u6210\u7ee9\u4f18\u5148\u7684\u89d2\u5ea6\u770b\uff0c\u4e5f\u8bb8\u7acb\u523b\u548c\u724c\u6700\u597d\uff1b\u4f46\u5982\u679c\u6709\u4eba\u4e3a\u4e86\u5927\u4e09\u5143\u7ee7\u7eed\u505a\u724c\uff0c\u90a3\u4e5f\u662f\u4ed6\u7684\u81ea\u7531\u9009\u62e9\u3002</p> <p>\u8fd9\u5957\u6559\u7a0b\u7684\u7acb\u573a\u4f1a\u6bd4\u8f83\u660e\u786e\uff1a</p> <p>\u6211\u5199\u8fd9\u4e9b\u5185\u5bb9\uff0c\u76ee\u6807\u662f\u5e2e\u52a9\u4f60\u63d0\u9ad8\u957f\u671f\u6210\u7ee9\u3002</p> <p>\u6240\u4ee5\u540e\u9762\u4f1a\u4e0d\u65ad\u5f3a\u8c03\uff1a</p> <ol> <li>\u4ec0\u4e48\u6253\u6cd5\u957f\u671f\u66f4\u8d5a</li> <li>\u4ec0\u4e48\u5224\u65ad\u66f4\u7a33\u5b9a</li> <li>\u4ec0\u4e48\u9009\u62e9\u53ea\u662f\u770b\u8d77\u6765\u5e05\uff0c\u5b9e\u9645\u5374\u5bb9\u6613\u4e8f</li> </ol> <p>\u4f46\u8fd9\u4e0d\u7b49\u4e8e\u6211\u5728\u8bf4\u201c\u9664\u4e86\u8fd9\u91cc\u5199\u7684\u6253\u6cd5\uff0c\u5176\u4ed6\u90fd\u4e0d\u8bb8\u6253\u201d\u3002\u5b83\u53ea\u662f\u544a\u8bc9\u4f60\uff1a\u5982\u679c\u76ee\u6807\u662f\u628a\u6210\u7ee9\u6253\u4e0a\u53bb\uff0c\u90a3\u4e48\u54ea\u4e9b\u9009\u62e9\u66f4\u503c\u5f97\u4f18\u5148\u5b66\u4e60\u3002</p>"},{"location":"kihon/kihon01.html#_4","title":"\u8fd9\u4e00\u9875\u7684\u7ed3\u8bba","text":"<ol> <li>\u9ebb\u5c06\u975e\u5e38\u5403\u8fd0\u6c14\uff0c\u4f46\u201c\u624b\u6c14\u7406\u8bba\u201d\u4e0d\u9002\u5408\u4f5c\u4e3a\u5b9e\u6218\u4f9d\u636e</li> <li>\u77ed\u671f\u80dc\u8d1f\u6ce2\u52a8\u5f88\u5927\uff0c\u4e0d\u80fd\u7528\u5355\u573a\u7ed3\u679c\u5012\u63a8\u6253\u6cd5\u5bf9\u9519</li> <li>\u8fd9\u5957\u6559\u7a0b\u4ee5\u201c\u63d0\u9ad8\u957f\u671f\u6210\u7ee9\u201d\u4e3a\u4e3b\u8981\u76ee\u6807</li> </ol> <p>\u4e0b\u4e00\u9875\u5f00\u59cb\uff0c\u4f1a\u8fdb\u5165\u4e00\u4e2a\u66f4\u5b9e\u5728\u7684\u95ee\u9898\uff1a\u65e2\u7136\u9ebb\u5c06\u672c\u8d28\u4e0a\u662f\u5728\u6bd4\u8c01\u66f4\u5feb\u3001\u66f4\u7a33\u5b9a\u5730\u5b8c\u6210\u624b\u724c\uff0c\u90a3\u6982\u7387\u8be5\u600e\u4e48\u7406\u89e3\uff1f</p> <p>\u539f\u59cb\u65e5\u6587\u9875\uff1ahttp://beginners.biz/kihon/kihon01.html</p>"},{"location":"kihon/kihon02.html","title":"\u9ebb\u5c06\u4e0e\u6982\u7387","text":"<p>\u4e00\u63d0\u5230\u201c\u505a\u724c\u201d\uff0c\u5f88\u591a\u4eba\u7b2c\u4e00\u53cd\u5e94\u662f\uff1a</p> <p>\u201c\u8fd9\u624b\u8be5\u505a\u4ec0\u4e48\u5f79\uff1f\u201d</p> <p>\u4f46\u5982\u679c\u628a\u9ebb\u5c06\u7684\u672c\u8d28\u6293\u5f97\u66f4\u51c6\u4e00\u4e9b\uff0c\u5c31\u4f1a\u53d1\u73b0\u8fd9\u4e0d\u662f\u6700\u6838\u5fc3\u7684\u95ee\u9898\u3002</p>"},{"location":"kihon/kihon02.html#_2","title":"\u505a\u724c\u7684\u672c\u8d28\u662f\u4ec0\u4e48","text":"<p>\u4e00\u526f\u5b8c\u6574\u548c\u724c\u624b\uff0c\u5f52\u6839\u5230\u5e95\u662f\uff1a</p> <p>\u56db\u7ec4\u9762\u5b50 + \u4e00\u7ec4\u96c0\u5934</p> <p>\u5982\u679c\u628a\u9ebb\u5c06\u5148\u5f53\u6210\u5355\u5c40\u5185\u7684\u7ade\u4e89\u6765\u770b\uff0c\u672c\u8d28\u4e0a\u5c31\u662f\uff1a</p> <p>\u56db\u4e2a\u4eba\u91cc\uff0c\u8c01\u6700\u5148\u628a\u201c\u56db\u9762\u5b50\u4e00\u96c0\u5934\u201d\u505a\u5b8c\u6574\u3002</p> <p>\u5f53\u7136\uff0c\u6700\u540e\u51b3\u5b9a\u80dc\u8d1f\u7684\u662f\u70b9\u6570\uff0c\u800c\u4e0d\u662f\u5355\u7eaf\u8c01\u5148\u548c\u724c\u3002\u4f46\u5728\u73b0\u4ee3\u9ebb\u5c06\u91cc\uff0c\u5b9d\u724c\u3001\u8d64\u724c\u3001\u795d\u4eea\u7b49\u56e0\u7d20\u4f1a\u5927\u5e45\u653e\u5927\u201c\u901f\u5ea6\u201d\u7684\u4ef7\u503c\u3002\u5f88\u591a\u65f6\u5019\uff0c\u5c31\u7b97\u6ca1\u6709\u7279\u522b\u6f02\u4eae\u7684\u624b\u5f79\uff0c\u53ea\u8981\u4f60\u5148\u628a\u724c\u505a\u6210\uff0c\u4e00\u6837\u80fd\u62ff\u5230\u5f88\u53ef\u89c2\u7684\u6536\u76ca\u3002</p> <p>\u6240\u4ee5\u8fd9\u91cc\u6700\u91cd\u8981\u7684\u8ba4\u8bc6\u662f\uff1a</p> <ol> <li>\u9ebb\u5c06\u5f53\u7136\u6709\u624b\u5f79</li> <li>\u4f46\u505a\u724c\u7684\u6838\u5fc3\u4e0d\u662f\u5148\u60f3\u201c\u6211\u8981\u505a\u4ec0\u4e48\u5f79\u201d</li> <li>\u800c\u662f\u5148\u60f3\u201c\u6211\u600e\u4e48\u66f4\u5feb\u628a\u5f62\u505a\u5b8c\u6574\u201d</li> </ol> <p>\u800c\u56f4\u7ed5\u8fd9\u4e2a\u95ee\u9898\u5c55\u5f00\u7684\uff0c\u5c31\u662f\u724c\u6548\u7387\u548c\u6982\u7387\u3002</p>"},{"location":"kihon/kihon02.html#1","title":"\u4f8b\u9898 1\uff1a\u5207\u54ea\u5f20\u66f4\u5bb9\u6613\u548c\u724c","text":"<p> \u78b0 \u81ea\u6478</p> <p>\u8fd9\u624b\u91cc\uff0c\u4e09\u7ec4\u9762\u5b50\u548c\u96c0\u5934\u90fd\u5df2\u7ecf\u5dee\u4e0d\u591a\u6210\u578b\uff0c\u53ea\u5dee\u6700\u540e\u4e00\u7ec4\u9762\u5b50\u3002</p> <p>\u5982\u679c\u5207 \uff0c\u90a3\u4e48\u53ea\u8981\u6478\u5230\u6216\u8363\u548c \u3001 \u5c31\u80fd\u548c\u724c\u3002</p> <p>\u5982\u679c\u5207 \uff0c\u5219\u57fa\u672c\u53ea\u5269\u7b49  \u8fd9\u4e00\u7c7b\u673a\u4f1a\u3002</p> <p>\u54ea\u8fb9\u66f4\u5bb9\u6613\u548c\u724c\uff0c\u5176\u5b9e\u4e0d\u7528\u7b97\u5f97\u592a\u7ec6\uff0c\u76f4\u89c9\u5c31\u80fd\u770b\u51fa\u6765\uff1a\u53d7\u5165\u79cd\u7c7b\u66f4\u591a\u7684\u4e00\u8fb9\u5f53\u7136\u66f4\u4f18\u3002</p>"},{"location":"kihon/kihon02.html#2","title":"\u4f8b\u9898 2\uff1a\u79cd\u7c7b\u4e00\u6837\uff0c\u679a\u6570\u4e0d\u4e00\u6837","text":"<p> \u78b0 \u81ea\u6478</p> <p>\u8fd9\u624b\u66f4\u6709\u4ee3\u8868\u6027\u3002</p> <p>\u542c\u724c\u5019\u9009\u662f\u5207  \u6216\u5207 \u3002</p> <p>\u8868\u9762\u770b\uff0c\u4e24\u8fb9\u90fd\u662f\u7b49\u4e24\u79cd\u724c\uff0c\u4f3c\u4e4e\u5dee\u4e0d\u591a\u3002\u4f46\u5b9e\u9645\u4e0a\u5dee\u5f88\u591a\uff1a</p> <ol> <li>\u5982\u679c\u4fdd\u7559\u7684\u662f\u81ea\u5df1\u5df2\u7ecf\u5927\u91cf\u4f7f\u7528\u8fc7\u7684\u724c\u578b\uff0c\u90a3\u4e48\u573a\u4e0a\u5269\u4f59\u679a\u6570\u4f1a\u51cf\u5c11</li> <li>\u5982\u679c\u4fdd\u7559\u7684\u662f\u81ea\u5df1\u8fd8\u6ca1\u538b\u7f29\u6389\u592a\u591a\u7684\u724c\u578b\uff0c\u90a3\u4e48\u5269\u4f59\u679a\u6570\u5c31\u66f4\u591a</li> </ol> <p>\u4e5f\u5c31\u662f\u8bf4\uff0c\u9ebb\u5c06\u4e0d\u80fd\u53ea\u770b\u201c\u6709\u51e0\u79cd\u53d7\u5165\u201d\uff0c\u8fd8\u8981\u770b\u201c\u6bcf\u79cd\u53d7\u5165\u8fd8\u5269\u591a\u5c11\u679a\u201d\u3002</p> <p>\u539f\u9875\u8fd9\u5f20\u56fe\u8868\u8fbe\u7684\u5c31\u662f\u8fd9\u4e2a\u610f\u601d\uff1a</p> <p></p> <p>\u6240\u4ee5\uff0c\u505a\u724c\u65f6\u771f\u6b63\u8be5\u517b\u6210\u7684\u57fa\u672c\u4e60\u60ef\u662f\uff1a</p> <p>\u9009\u62e9\u90a3\u79cd\u80fd\u8ba9\u81ea\u5df1\u4ee5\u66f4\u9ad8\u6982\u7387\u62bd\u4e2d\u548c\u724c\u724c\u7684\u6253\u724c\u3002</p> <p>\u8fd9\u5c31\u662f\u724c\u6548\u7387\u6700\u57fa\u7840\u7684\u51fa\u53d1\u70b9\u3002</p>"},{"location":"kihon/kihon02.html#_3","title":"\u4e0d\u8981\u88ab\u5355\u6b21\u7ed3\u679c\u5e26\u7740\u8d70","text":"<p>\u9ebb\u5c06\u5728\u521d\u5b66\u9636\u6bb5\u6700\u5bb9\u6613\u72af\u7684\u9519\u8bef\u4e4b\u4e00\uff0c\u5c31\u662f\u7528\u4e00\u6b21\u7ed3\u679c\u53bb\u5426\u5b9a\u957f\u671f\u6b63\u786e\u9009\u62e9\u3002</p> <p>\u6bd4\u5982\u4f60\u6309\u724c\u6548\u7387\u5207\u724c\u540e\uff0c\u7ed3\u679c\u540e\u6765\u53e6\u4e00\u8fb9\u7684\u724c\u5148\u51fa\u6765\u4e86\uff0c\u4e8e\u662f\u4f60\u5c31\u4f1a\u540e\u6094\uff1a\u201c\u65e9\u77e5\u9053\u521a\u624d\u5207\u53e6\u4e00\u5f20\u3002\u201d</p> <p>\u8fd9\u79cd\u60f3\u6cd5\u5f88\u5371\u9669\uff0c\u56e0\u4e3a\u5b83\u4f1a\u628a\u4f60\u5e26\u56de\u7ed3\u679c\u8bba\u3002</p> <p>\u9ebb\u5c06\u662f\u4e00\u4e2a\u9ad8\u6ce2\u52a8\u6e38\u620f\u3002\u5373\u4f7f\u4f60\u505a\u4e86\u957f\u671f\u6700\u4f18\u9009\u62e9\uff0c\u77ed\u671f\u4e5f\u5b8c\u5168\u53ef\u80fd\u8f93\uff1b\u53cd\u8fc7\u6765\uff0c\u5c31\u7b97\u4f60\u505a\u4e86\u660e\u663e\u4e8f\u635f\u9009\u62e9\uff0c\u4e5f\u7ecf\u5e38\u4f1a\u201c\u521a\u597d\u6210\u4e86\u201d\u3002</p> <p>\u56e0\u6b64\uff0c\u771f\u6b63\u5e94\u8be5\u95ee\u7684\u4e0d\u662f\uff1a</p> <p>\u201c\u8fd9\u4e00\u6b21\u7ed3\u679c\u597d\u4e0d\u597d\uff1f\u201d</p> <p>\u800c\u662f\uff1a</p> <p>\u201c\u5982\u679c\u628a\u8fd9\u79cd\u9009\u62e9\u91cd\u590d\u5f88\u591a\u6b21\uff0c\u54ea\u8fb9\u6574\u4f53\u66f4\u8d5a\uff1f\u201d</p>"},{"location":"kihon/kihon02.html#_4","title":"\u8fd9\u4e00\u9875\u7684\u7ed3\u8bba","text":"<ol> <li>\u505a\u724c\u7684\u6838\u5fc3\uff0c\u662f\u66f4\u5feb\u5b8c\u6210\u201c\u56db\u9762\u5b50\u4e00\u96c0\u5934\u201d</li> <li>\u724c\u6548\u7387\u672c\u8d28\u4e0a\u662f\u6982\u7387\u95ee\u9898</li> <li>\u9009\u62e9\u6253\u724c\u65f6\uff0c\u8981\u4f18\u5148\u4fdd\u7559\u53d7\u5165\u66f4\u591a\u3001\u679a\u6570\u66f4\u5927\u7684\u8def\u7ebf</li> <li>\u4e0d\u8981\u7528\u5355\u6b21\u7ed3\u679c\u5426\u5b9a\u957f\u671f\u6b63\u786e\u9009\u62e9</li> </ol> <p>\u4e0b\u4e00\u6b65\uff0c\u5c31\u4f1a\u8fdb\u5165\u66f4\u7ec6\u7684\u5185\u5bb9\uff1a\u542c\u724c\u3001\u5411\u542c\uff0c\u4ee5\u53ca\u724c\u5f62\u672c\u8eab\u5230\u5e95\u8be5\u600e\u4e48\u62c6\u3001\u600e\u4e48\u7406\u89e3\u3002</p> <p>\u539f\u59cb\u65e5\u6587\u9875\uff1ahttp://beginners.biz/kihon/kihon02.html</p>"}]}